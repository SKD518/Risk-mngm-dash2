<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5">
  <title>RISK COMMAND · Нефтегаз</title>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #0A0C10;
      font-family: 'Inter', sans-serif;
      color: #EFF3F8;
      padding: 24px 20px;
    }

    .dashboard-container {
      max-width: 1600px;
      margin: 0 auto;
    }

    /* Шапка */
    .dashboard-header {
      margin-bottom: 28px;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-end;
      gap: 16px;
      border-bottom: 1px solid #2A2E3A;
      padding-bottom: 18px;
    }

    .title-section h1 {
      font-size: 1.9rem;
      font-weight: 600;
      letter-spacing: -0.3px;
      background: linear-gradient(135deg, #FFFFFF 0%, #9BB8E0 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .title-section p {
      font-size: 0.85rem;
      color: #8891AA;
      margin-top: 6px;
    }

    .badge-date {
      background: #1A1E28;
      padding: 6px 14px;
      border-radius: 40px;
      font-size: 0.8rem;
      font-weight: 500;
      color: #B9C3E6;
      border: 1px solid #2F3545;
    }

    /* KPI карточки */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 32px;
    }

    .kpi-card {
      background: #11141C;
      border-radius: 24px;
      padding: 20px 18px;
      border: 1px solid #262C38;
      transition: all 0.2s;
      box-shadow: 0 6px 12px rgba(0,0,0,0.3);
    }

    .kpi-card:hover {
      border-color: #3A4A6E;
      background: #131824;
    }

    .kpi-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
      color: #8A95B0;
      margin-bottom: 12px;
    }

    .kpi-value {
      font-size: 2.5rem;
      font-weight: 700;
      color: white;
      line-height: 1.1;
      margin-bottom: 6px;
    }

    .kpi-sub {
      font-size: 0.75rem;
      color: #6C7A9E;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .trend-up { color: #F9735C; }
    .trend-down { color: #4BC0A9; }

    /* Двухколоночная сетка */
    .two-col-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-bottom: 32px;
    }

    .left-stack {
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .right-stack {
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .widget {
      background: #11141C;
      border-radius: 28px;
      border: 1px solid #262C38;
      overflow: hidden;
    }

    .widget-header {
      padding: 18px 22px 8px 22px;
      font-weight: 600;
      font-size: 1.2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #222835;
    }

    .widget-header h3 {
      font-size: 1.2rem;
      font-weight: 600;
    }

    .widget-body {
      padding: 18px 22px 22px 22px;
    }

    /* Тепловая карта */
    .heatmap-matrix {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .heatmap-row {
      display: grid;
      grid-template-columns: 90px repeat(5, 1fr);
      align-items: center;
    }

    .heatmap-label {
      font-size: 0.75rem;
      font-weight: 500;
      color: #9AA4C2;
      text-align: center;
    }

    .heatmap-cell {
      background: #1E232F;
      margin: 2px;
      border-radius: 12px;
      text-align: center;
      padding: 10px 2px;
      font-weight: 600;
      font-size: 0.8rem;
      transition: 0.1s;
      cursor: default;
    }

    .risk-critical { background: #B91C1C; color: white; box-shadow: 0 0 4px #B91C1C; }
    .risk-high { background: #E25822; color: white; }
    .risk-medium { background: #F5B042; color: #0A0C10; }
    .risk-low { background: #2C6E4F; color: white; }

    .heatmap-cell small {
      font-size: 0.65rem;
      font-weight: normal;
      display: block;
      opacity: 0.8;
    }

    /* Таблица топ-рисков */
    .incidents-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.8rem;
    }

    .incidents-table th {
      text-align: left;
      padding: 12px 4px 8px 0;
      color: #8E99B5;
      font-weight: 500;
      border-bottom: 1px solid #262D3A;
    }

    .incidents-table td {
      padding: 12px 4px 12px 0;
      border-bottom: 1px solid #1E232F;
    }

    .priority-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 40px;
      font-size: 0.7rem;
      font-weight: 600;
    }

    .priority-high { background: #B91C1C20; color: #FF7A5C; border-left: 2px solid #E25822; }
    .priority-med { background: #F5B04220; color: #F5C542; }

    .status-badge {
      background: #1F2A3E;
      border-radius: 16px;
      padding: 4px 10px;
      font-size: 0.7rem;
    }

    /* График */
    .chart-container {
      position: relative;
      height: 220px;
      width: 100%;
    }

    /* Просроченные действия */
    .overdue-list {
      list-style: none;
    }

    .overdue-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid #1F2532;
    }

    .overdue-title {
      font-weight: 500;
    }

    .overdue-date {
      font-size: 0.7rem;
      color: #F9735C;
      background: #2A1C1C;
      padding: 4px 10px;
      border-radius: 40px;
    }

    /* Фильтр */
    .filter-bar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .filter-chip {
      background: #1A1F2A;
      padding: 6px 18px;
      border-radius: 40px;
      font-size: 0.75rem;
      font-weight: 500;
      cursor: pointer;
      transition: 0.2s;
      border: 1px solid #2E3442;
    }

    .filter-chip.active,
    .filter-chip:hover {
      background: #2C5F7A;
      border-color: #4694B3;
      color: white;
    }

    /* Футер */
    footer {
      margin-top: 30px;
      text-align: center;
      font-size: 0.7rem;
      color: #4A5570;
      border-top: 1px solid #1E2430;
      padding-top: 20px;
    }

    .footnote {
      color: #5B6885;
    }

    /* Адаптивность */
    @media (max-width: 1000px) {
      .two-col-grid {
        grid-template-columns: 1fr;
        gap: 28px;
      }
      .kpi-value {
        font-size: 2rem;
      }
    }

    @media (max-width: 620px) {
      body { padding: 16px; }
      .widget-body { padding: 12px 16px; }
      .heatmap-row { grid-template-columns: 70px repeat(5, 1fr); }
    }
  </style>
</head>
<body>
<div class="dashboard-container">

  <!-- Шапка -->
  <div class="dashboard-header">
    <div class="title-section">
      <h1>⚡ RISK COMMAND • НЕФТЕГАЗ</h1>
      <p>Оперативный дашборд риск-менеджера | Мониторинг KRI & просроченные меры</p>
    </div>
    <div class="badge-date">
      📅 Актуально: 20.04.2026
    </div>
  </div>

  <!-- Фильтр по категориям -->
  <div class="filter-bar" id="categoryFilterBar">
    <div class="filter-chip active" data-cat="all">Все категории</div>
    <div class="filter-chip" data-cat="Логистический">🚚 Логистика</div>
    <div class="filter-chip" data-cat="Технический">⚙️ Технические</div>
    <div class="filter-chip" data-cat="Финансовый">💰 Финансовые</div>
    <div class="filter-chip" data-cat="Безопасность">🛡️ Безопасность</div>
  </div>

  <!-- KPI карточки -->
  <div class="kpi-grid" id="kpiGrid"></div>

  <!-- Основная двухколоночная область -->
  <div class="two-col-grid">
    <!-- Левая колонка: тепловая карта + таблица топ-5 -->
    <div class="left-stack">
      <!-- Тепловая карта -->
      <div class="widget">
        <div class="widget-header">
          <h3>🔥 Тепловая карта рисков (вероятность × влияние)</h3>
          <span style="font-size:0.7rem;">плотность по категории</span>
        </div>
        <div class="widget-body">
          <div id="heatmapContainer" class="heatmap-matrix"></div>
        </div>
      </div>

      <!-- Топ-5 рисков -->
      <div class="widget">
        <div class="widget-header">
          <h3>📋 Топ-5 критических рисков</h3>
          <span style="font-size:0.7rem;">приоритет = P×I</span>
        </div>
        <div class="widget-body">
          <table class="incidents-table">
            <thead>
              <tr><th>Риск</th><th>Категория</th><th>Приоритет</th><th>Статус</th></tr>
            </thead>
            <tbody id="incidentsBody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Правая колонка: график KRI + просроченные меры -->
    <div class="right-stack">
      <!-- График KRI -->
      <div class="widget">
        <div class="widget-header">
          <h3>📈 KRI тренд: Индекс надежности поставок</h3>
          <span style="font-size:0.7rem;">порог тревоги &lt; 65%</span>
        </div>
        <div class="widget-body">
          <div class="chart-container">
            <canvas id="kriTrendChart"></canvas>
          </div>
          <div style="margin-top: 10px; font-size:0.7rem; display: flex; justify-content: space-between;">
            <span>▼ Ноябрь-декабрь: сбои логистики</span>
            <span>🎯 Целевой KRI: >75%</span>
          </div>
        </div>
      </div>

      <!-- Просроченные действия -->
      <div class="widget">
        <div class="widget-header">
          <h3>⏰ Просроченные меры реагирования</h3>
          <span style="color:#F9735C;">⚠️ требуют внимания</span>
        </div>
        <div class="widget-body">
          <ul class="overdue-list" id="overdueActionsList"></ul>
          <div style="margin-top: 14px; font-size:0.7rem; color:#EAA85C; background:#1F1B12; border-radius:20px; padding: 8px 12px;">
            📌 Владельцам рисков: подтвердить корректирующие действия до 25.04
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer>
    <span>🔍 Источник: внутренняя RMIS | Управление рисками нефтегазового кластера</span><br>
    <span class="footnote">Высокий риск (критический) — красный / средний — оранжевый / низкий — зеленый</span>
  </footer>
</div>

<script>
  (function(){
    "use strict";

    // ---------- ДАННЫЕ (учебный реестр рисков) ----------
    const risksData = [
      { id: "R-01", name: "Срыв поставок трубопроводной арматуры", category: "Логистический", probability: 5, impact: 5, level: "Критический", status: "Открыт", owner: "Директор по закупкам", dueDate: "2026-03-15", measure: "Ускорение тендера" },
      { id: "R-02", name: "Отказ ГТУ на компрессорной станции", category: "Технический", probability: 4, impact: 5, level: "Высокий", status: "Под контролем", owner: "Главный инженер", dueDate: "2026-05-01", measure: "Плановый ремонт" },
      { id: "R-03", name: "Рост стоимости металлопроката", category: "Финансовый", probability: 4, impact: 4, level: "Высокий", status: "Открыт", owner: "Финансовый контролер", dueDate: "2026-04-10", measure: "Хеджирование" },
      { id: "R-04", name: "Кибератака на SCADA", category: "Безопасность", probability: 3, impact: 5, level: "Высокий", status: "Открыт", owner: "CISO", dueDate: "2026-03-28", measure: "Аудит защиты" },
      { id: "R-05", name: "Недостаток квалифицированных операторов", category: "Технический", probability: 3, impact: 3, level: "Средний", status: "Под контролем", owner: "HR-директор", dueDate: "2026-06-01", measure: "Найм персонала" },
      { id: "R-06", name: "Разлив нефти при перевалке", category: "Безопасность", probability: 2, impact: 5, level: "Высокий", status: "Открыт", owner: "Начальник Добычи", dueDate: "2026-04-05", measure: "Усиление протоколов" },
      { id: "R-07", name: "Простой морского терминала из-за шторма", category: "Логистический", probability: 4, impact: 4, level: "Высокий", status: "Открыт", owner: "Логист", dueDate: "2026-03-22", measure: "Резервный маршрут" },
      { id: "R-08", name: "Волатильность курса рубля", category: "Финансовый", probability: 5, impact: 3, level: "Средний", status: "Под контролем", owner: "Казначейство", dueDate: "2026-04-20", measure: "Валютный своп" },
      { id: "R-09", name: "Пожар на объекте ПНГ", category: "Безопасность", probability: 1, impact: 5, level: "Средний", status: "Закрыт", owner: "HSE", dueDate: "2026-02-10", measure: "Установка систем" },
      { id: "R-10", name: "Задержка выдачи лицензии на участок", category: "Регуляторный", probability: 2, impact: 4, level: "Средний", status: "Открыт", owner: "Юр. отдел", dueDate: "2026-05-15", measure: "Претензия" }
    ];

    // Сегодняшняя дата для просрочек
    const today = new Date();
    today.setHours(0,0,0,0);

    // ---------- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ----------
    function getOverdueActions() {
      return risksData.filter(r => {
        if (!r.dueDate || r.status === "Закрыт") return false;
        const due = new Date(r.dueDate);
        return due < today;
      }).map(r => ({
        name: r.name,
        due: r.dueDate,
        owner: r.owner,
        measure: r.measure
      }));
    }

    function computeKPIs() {
      const total = risksData.length;
      const criticalHigh = risksData.filter(r => r.level === "Критический" || r.level === "Высокий").length;
      const open = risksData.filter(r => r.status === "Открыт").length;
      const overdue = getOverdueActions().length;
      return { total, criticalHigh, open, overdue };
    }

    // ---------- РЕНДЕРИНГ KPI ----------
    function renderKPIs() {
      const kpis = computeKPIs();
      const grid = document.getElementById("kpiGrid");
      grid.innerHTML = `
        <div class="kpi-card"><div class="kpi-label">📊 ВСЕГО РИСКОВ</div><div class="kpi-value">${kpis.total}</div><div class="kpi-sub">актуальный реестр</div></div>
        <div class="kpi-card"><div class="kpi-label">⚠️ КРИТИЧЕСКИЕ / ВЫСОКИЕ</div><div class="kpi-value">${kpis.criticalHigh}</div><div class="kpi-sub"><span class="trend-up">требуют эскалации</span></div></div>
        <div class="kpi-card"><div class="kpi-label">📂 ОТКРЫТЫЕ РИСКИ</div><div class="kpi-value">${kpis.open}</div><div class="kpi-sub">без контроля → ${Math.round(kpis.open/kpis.total*100)}%</div></div>
        <div class="kpi-card"><div class="kpi-label">⌛ ПРОСРОЧЕННЫЕ МЕРЫ</div><div class="kpi-value">${kpis.overdue}</div><div class="kpi-sub"><span class="trend-up">требуют вмешательства</span></div></div>
      `;
    }

    // ---------- ТЕПЛОВАЯ КАРТА (матрица 5x5) ----------
    function renderHeatmap(filterCategory = "all") {
      const filtered = filterCategory === "all" ? risksData : risksData.filter(r => r.category === filterCategory);
      const matrix = Array(5).fill().map(() => Array(5).fill(0));
      
      filtered.forEach(risk => {
        const probIdx = risk.probability - 1;
        const impIdx = risk.impact - 1;
        if (probIdx >=0 && probIdx <5 && impIdx>=0 && impIdx<5) {
          matrix[impIdx][probIdx] += 1;
        }
      });

      const maxCount = Math.max(1, ...matrix.flat());
      const getColorClass = (count) => {
        if (count === 0) return "";
        const intensity = count / maxCount;
        if (intensity > 0.6) return "risk-critical";
        if (intensity > 0.3) return "risk-high";
        if (intensity > 0.1) return "risk-medium";
        return "risk-low";
      };

      const probLabels = ["1 (редко)", "2 (малая)", "3 (средняя)", "4 (высокая)", "5 (почти точно)"];
      const impactLabels = ["5 Критич.", "4 Значит.", "3 Умерен.", "2 Низкое", "1 Миним."];

      let html = `<div class="heatmap-row"><div class="heatmap-label"></div>${probLabels.map(l => `<div class="heatmap-label" style="text-align:center">${l}</div>`).join('')}</div>`;
      
      for (let i = 0; i < 5; i++) {
        html += `<div class="heatmap-row"><div class="heatmap-label">${impactLabels[i]}</div>`;
        for (let j = 0; j < 5; j++) {
          const count = matrix[i][j];
          const cls = getColorClass(count);
          html += `<div class="heatmap-cell ${cls}">${count || 0}${count ? `<small>рис.</small>` : ''}</div>`;
        }
        html += `</div>`;
      }
      document.getElementById("heatmapContainer").innerHTML = html;
    }

    // ---------- ТОП-5 РИСКОВ (сортировка по приоритету) ----------
    function renderTopIncidents(filterCategory = "all") {
      let filtered = filterCategory === "all" ? [...risksData] : risksData.filter(r => r.category === filterCategory);
      const sorted = filtered.sort((a,b) => (b.probability * b.impact) - (a.probability * a.impact)).slice(0,5);
      const tbody = document.getElementById("incidentsBody");
      tbody.innerHTML = "";
      
      sorted.forEach(risk => {
        const priority = risk.probability * risk.impact;
        const priorityClass = priority >= 20 ? "priority-high" : "priority-med";
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td><strong>${risk.name}</strong><br><span style="font-size:0.7rem; color:#8A95B0;">${risk.id}</span></td>
          <td>${risk.category}</td>
          <td><span class="priority-badge ${priorityClass}">${priority} (${risk.probability}×${risk.impact})</span></td>
          <td><span class="status-badge">${risk.status}</span></td>
        `;
        tbody.appendChild(tr);
      });
    }

    // ---------- ПРОСРОЧЕННЫЕ ДЕЙСТВИЯ ----------
    function renderOverdue() {
      const overdue = getOverdueActions();
      const list = document.getElementById("overdueActionsList");
      list.innerHTML = "";
      
      if (overdue.length === 0) {
        list.innerHTML = `<li class="overdue-item" style="justify-content: center; color: #6C7A9E;">✅ Нет просроченных мер</li>`;
        return;
      }
      
      const displayItems = overdue.slice(0, 4);
      displayItems.forEach(item => {
        const li = document.createElement("li");
        li.className = "overdue-item";
        li.innerHTML = `
          <div>
            <strong>${item.name}</strong>
            <div style="font-size:0.7rem; color:#A5B3D6;">👤 ${item.owner}</div>
            <div style="font-size:0.7rem; color:#8891AA;">📋 ${item.measure}</div>
          </div>
          <div class="overdue-date">⏳ просрочено: ${item.due}</div>
        `;
        list.appendChild(li);
      });
      
      if (overdue.length > 4) {
        const moreLi = document.createElement("li");
        moreLi.className = "overdue-item";
        moreLi.innerHTML = `<div style="font-size:0.7rem;">+ ещё ${overdue.length - 4} просроченных мер</div>`;
        list.appendChild(moreLi);
      }
    }

    // ---------- ГРАФИК KRI (Chart.js) ----------
    let kriChart;
    function initKRIChart() {
      const ctx = document.getElementById('kriTrendChart').getContext('2d');
      const months = ['Сен 25', 'Окт 25', 'Ноя 25', 'Дек 25', 'Янв 26', 'Фев 26', 'Мар 26', 'Апр 26'];
      const kriValues = [82, 78, 68, 59, 63, 70, 74, 71];
      
      if (kriChart) kriChart.destroy();
      kriChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: months,
          datasets: [{
            label: 'Индекс надёжности (%)',
            data: kriValues,
            borderColor: '#4BC0A9',
            backgroundColor: 'rgba(75, 192, 169, 0.05)',
            borderWidth: 3,
            pointBackgroundColor: '#EFF3F8',
            pointBorderColor: '#0A0C10',
            pointRadius: 4,
            pointHoverRadius: 6,
            tension: 0.2,
            fill: true
          }, {
            label: 'Порог тревоги (65%)',
            data: Array(months.length).fill(65),
            borderColor: '#F9735C',
            borderWidth: 2,
            borderDash: [5, 5],
            pointRadius: 0,
            fill: false
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { labels: { color: '#B9C3E6', font: { size: 11 } } },
            tooltip: { backgroundColor: '#1A1E28', titleColor: '#EFF3F8', bodyColor: '#B9C3E6' }
          },
          scales: {
            y: {
              min: 45,
              max: 90,
              grid: { color: '#252C3C' },
              ticks: { color: '#B0BFE0' }
            },
            x: {
              ticks: { color: '#A7B3D0' }
            }
          }
        }
      });
    }

    // ---------- ФИЛЬТР И ОБНОВЛЕНИЕ ----------
    let activeCategory = "all";
    function updateDashboardByCategory(cat) {
      activeCategory = cat;
      renderHeatmap(cat);
      renderTopIncidents(cat);
      
      document.querySelectorAll('.filter-chip').forEach(chip => {
        if (chip.dataset.cat === cat) chip.classList.add('active');
        else chip.classList.remove('active');
      });
    }

    function bindFilters() {
      document.querySelectorAll('.filter-chip').forEach(chip => {
        chip.addEventListener('click', () => {
          updateDashboardByCategory(chip.dataset.cat);
        });
      });
    }

    // ---------- ИНИЦИАЛИЗАЦИЯ ----------
    function init() {
      renderKPIs();
      renderHeatmap("all");
      renderTopIncidents("all");
      renderOverdue();
      initKRIChart();
      bindFilters();
    }

    init();
  })();
</script>
</body>
</html>

